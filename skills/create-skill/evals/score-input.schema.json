{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "suite_version", "matrix_phase", "case_id", "arm", "harness", "harness_version", "model", "model_snapshot", "iteration", "run_index", "started_at", "assertions", "tokens", "latency_ms", "tool_calls", "actor_sessions"],
  "properties": {
    "schema_version": {"const": 1},
    "suite_version": {"type": "string", "minLength": 1},
    "matrix_phase": {"enum": ["pilot", "expansion"]},
    "case_id": {"type": "string", "minLength": 1},
    "arm": {"enum": ["prompt", "skill", "trigger"]},
    "harness": {"type": "string", "minLength": 1},
    "harness_version": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "model_snapshot": {"type": ["string", "null"], "minLength": 1},
    "iteration": {"type": "integer", "minimum": 1},
    "run_index": {"type": "integer", "minimum": 1},
    "started_at": {"type": "string", "format": "date-time"},
    "assertions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "method", "evidence_paths"],
        "properties": {
          "score": {"enum": [0, 1]},
          "method": {"enum": ["mechanical", "blinded-judge"]},
          "evidence_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "sha256"],
              "properties": {
                "path": {"type": "string", "minLength": 1},
                "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
              },
              "additionalProperties": false
            }
          },
          "judge_prompt_path": {"type": ["string", "null"]},
          "judge_output_path": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "trigger_observed": {"type": ["string", "null"]},
    "tokens": {"type": "integer", "minimum": 0},
    "latency_ms": {"type": "integer", "minimum": 0},
    "tool_calls": {"type": "integer", "minimum": 0},
    "actor_sessions": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
